<section id="contact" class="contact">
  <div class="contact-inner">
    <div class="contact-content">
      <p class="section-eyebrow">Let's Work Together</p>
      <h2 class="section-title">Get in Touch</h2>
      <p class="contact-text">
        Have a project in mind or need help with your infrastructure? Reach out and let's discuss
        how we can help.
      </p>
      <div class="contact-methods">
        <a href="mailto:hello@meappy.com" class="contact-card">
          <span class="contact-icon">
            <svg
              width="22"
              height="22"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
          </span>
          <div>
            <strong>Email</strong>
            <span>hello@meappy.com</span>
          </div>
        </a>
        <!-- TODO: Add LinkedIn once company page is set up -->
        <!-- TODO: Add GitHub once profile is cleaned up -->
      </div>
    </div>

    <div class="contact-booking">
      <h3 class="booking-title">Book a Call</h3>
      <div class="cal-embed-container" id="my-cal-inline"></div>
    </div>

    <div class="contact-map-section">
      <h3 class="map-title">Our Locations</h3>
      <div class="map-container" id="location-map"></div>
      <div class="map-labels">
        <div class="map-label">
          <span class="map-pin"></span>
          <span>Adelaide, Australia</span>
        </div>
        <div class="map-label">
          <span class="map-pin"></span>
          <span>Singapore</span>
        </div>
      </div>
    </div>
  </div>
</section>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />

<style>
  .contact {
    padding: var(--section-padding);
  }

  .contact-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .contact-content {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .section-eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .contact-text {
    font-size: 1.05rem;
    line-height: 1.7;
    color: var(--color-text-muted);
    margin-bottom: 2.5rem;
  }

  .contact-methods {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color var(--transition), transform var(--transition);
  }

  .contact-card:hover {
    border-color: rgba(0, 212, 255, 0.2);
    transform: translateX(4px);
  }

  .contact-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 212, 255, 0.08);
    border-radius: 10px;
    color: var(--color-accent);
  }

  .contact-card strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 0.15rem;
  }

  .contact-card span {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .contact-booking {
    margin-bottom: 3rem;
  }

  .booking-title,
  .map-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }

  .cal-embed-container {
    width: 100%;
    height: 600px;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  .contact-map-section {
    margin-bottom: 1rem;
  }

  .map-container {
    width: 100%;
    height: 360px;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .map-labels {
    display: flex;
    gap: 2rem;
    margin-top: 1rem;
  }

  .map-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .map-pin {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-accent);
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.5);
  }

  @media (max-width: 768px) {
    .contact-card {
      padding: 1rem 1.25rem;
    }

    .map-container {
      height: 280px;
    }

    .cal-embed-container {
      height: 500px;
    }

    .map-labels {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>

<script>
  // Leaflet map
  async function initMap() {
    const L = await import('https://unpkg.com/leaflet@1.9.4/dist/leaflet-src.esm.js');

    const map = L.map('location-map', {
      zoomControl: false,
      attributionControl: false,
      scrollWheelZoom: false,
      dragging: true,
    }).setView([-15, 120], 3);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
      maxZoom: 19,
    }).addTo(map);

    L.control.attribution({ prefix: false }).addTo(map);

    const pinIcon = L.divIcon({
      className: 'custom-pin',
      html: '<div style="width:14px;height:14px;background:#00d4ff;border-radius:50%;box-shadow:0 0 12px rgba(0,212,255,0.6),0 0 24px rgba(0,212,255,0.3);border:2px solid rgba(0,212,255,0.8);"></div>',
      iconSize: [14, 14],
      iconAnchor: [7, 7],
    });

    const adelaide = L.marker([-34.9285, 138.6007], { icon: pinIcon }).addTo(map);
    adelaide.bindPopup(
      '<div style="font-family:Inter,sans-serif;font-size:13px;font-weight:600;color:#e8e8e8;background:#161616;padding:4px 8px;border-radius:6px;">Adelaide, Australia</div>',
      { className: 'dark-popup' }
    );

    const singapore = L.marker([1.3521, 103.8198], { icon: pinIcon }).addTo(map);
    singapore.bindPopup(
      '<div style="font-family:Inter,sans-serif;font-size:13px;font-weight:600;color:#e8e8e8;background:#161616;padding:4px 8px;border-radius:6px;">Singapore</div>',
      { className: 'dark-popup' }
    );

    const bounds = L.latLngBounds([[-34.9285, 138.6007], [1.3521, 103.8198]]);
    map.fitBounds(bounds, { padding: [60, 60] });
  }

  initMap();

  // Cal.com embed
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement('script')).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        typeof namespace === 'string' ? (cal.ns[namespace] = api) && p(api, ar) : p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window, 'https://app.cal.com/embed/embed.js', 'init');

  Cal('init', { origin: 'https://cal.com' });

  Cal('inline', {
    elementOrSelector: '#my-cal-inline',
    calLink: 'geraldsim',
    layout: 'month_view',
  });

  Cal('ui', {
    theme: 'dark',
    styles: { branding: { brandColor: '#00d4ff' } },
    hideEventTypeDetails: false,
    layout: 'month_view',
  });
</script>

<style is:global>
  .leaflet-popup-content-wrapper {
    background: #161616 !important;
    border: 1px solid #222 !important;
    border-radius: 8px !important;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5) !important;
  }

  .leaflet-popup-tip {
    background: #161616 !important;
  }

  .leaflet-popup-content {
    margin: 0 !important;
  }

  .dark-popup .leaflet-popup-close-button {
    display: none;
  }
</style>
